---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <section class="px-20">
        <div class="text-8xl font-black py-3">Your Cart</div>
        <div class="text-2xl opacity-65">
            Review your tactile selections before checkout.
        </div>
    </section>


    <div class="flex">
        <div class="flex flex-2 gap-10">
            <section class="flex gap-6 flex-col">
                <div class="flex">
                    <div><img src="/img camisa carrito.png" alt="" /></div>
                    <div>
                        <div class="text-6xl text-black font-bold">
                            Heavy Box Tee
                        </div>
                        <div class="py-4 opacity-65">Vintage White / XL</div>
                        <div>Amount: 1</div>
                        <div class="flex justify-end">$85.00</div>
                        <div class="text-2xl fond-bold flex justify-end">
                            Remove
                        </div>
                    </div>
                </div>
                <div class="flex">
                    <div><img src="/chaqueta carrito.png" alt="" /></div>
                    <div>
                        <div class="text-6xl text-black font-bold">
                            Atelier Overcoat
                        </div>
                        <div class="py-4 opacity-65">Charcoal / Large</div>
                        <div>Amount: 1</div>
                        <div class="flex justify-end">$640.00</div>
                        <div class="text-2xl fond-bold flex justify-end">
                            Remove
                        </div>
                    </div>
                </div>
            </section>
        </div>
    
        <section class="flex-1">
            <section class="flex gap-6 justify-end text-4xl font-black p-5 top-4-4">
                <div><p>Summary</p></div>
            </section>
            <div>
                <div
                    class="flex justify-between items-center px-10 sticky top-0 z-30"
                >
                    <div class="opacity-65">Subtotal</div>
                    <div class="py-4">$945.00</div>
                </div>
                <div
                    class="flex justify-between items-center px-10 sticky top-0 z-30"
                >
                    <div class="opacity-65">Estimated Shipping</div>
                    <div class="py-4">$15.00</div>
                </div>
                <div
                    class="flex justify-between items-center px-10 sticky top-0 z-30"
                >
                    <div class="opacity-65">Tax</div>
                    <div class="py-4">$78.40</div>
                </div>
                <div
                    class="flex justify-between items-center px-10 sticky top-0 z-30"
                >
                    <div class="text-2xl fond-bold">Total</div>
                    <div class="py-4 text-4xl font-medium">$1,038.40</div>
                </div>
                <div class="flex justify-end px-8">
                    <button class="font-light bg-blue-500 text-mist-50 p-4 py-2">
                       <a href="/" class="text-mist-50 no-underline">Proceed to Checkout</a>
                    </button>
                </div>
            </div>
        </section>
    </div>
</Layout>
