---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <div class="py-6 px-96">
        <p class="text-black text-2xl py-8">CONTACT</p>
        <form action="">
            <div class="flex flex-col">
                Name
                <input
                    type="text"
                    class="border-b border-amber-300 border-dashed"
                />
            </div>
            <div class="flex flex-col">
                Last Name
                <input
                    type="text"
                    class="border-b border-amber-300 border-dashed"
                />
            </div>
            <div class="flex flex-col">
                G-mail
                <input
                    type="text"
                    class="border-b border-amber-300 border-dashed"
                />
            </div>
            <div>
                <button class="font-light bg-blue-500 text-mist-50 p-6 py-2">
					<a href="">Register</a>
				</button>
            </div>
        </form>
    </div>
</Layout>
